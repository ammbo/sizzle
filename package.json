{
  "name": "sizzle-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && wrangler deploy --dry-run",
    "deploy": "bash scripts/deploy.sh",
    "deploy:cf": "wrangler deploy",
    "deploy:alicloud": "bash scripts/deploy.sh --alicloud-only",
    "dev": "wrangler dev",
    "types": "wrangler types worker-configuration.d.ts",
    "setup": "bash scripts/setup.sh"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
